{
  // Run/Debug configs for the Sprout Flutter app.
  //
  // The Nature Hunt labels photos with the Google Cloud Vision API. Paste your
  // API key below (replace PASTE_YOUR_VISION_API_KEY) — it's injected at build
  // time via --dart-define so it never lives in the source code. Don't commit a
  // real key. Without a key the hunt still runs and falls back to a manual picker.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sprout (debug)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define=VISION_API_KEY=AIzaSyC9f4CdLIdwi6hh8qdKZPq0pFdNK3XY6RQ"]
    },
    {
      "name": "Sprout (profile)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "toolArgs": ["--dart-define=VISION_API_KEY=AIzaSyC9f4CdLIdwi6hh8qdKZPq0pFdNK3XY6RQ"]
    },
    {
      "name": "Sprout (release)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define=VISION_API_KEY=AIzaSyC9f4CdLIdwi6hh8qdKZPq0pFdNK3XY6RQ"]
    }
  ]
}
